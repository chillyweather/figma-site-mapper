# MongoDB Connection String
# Replace with your actual connection string from MongoDB Atlas
MONGO_URI="mongodb+srv://username:password@cluster.mongodb.net/dev?retryWrites=true&w=majority"

# Node Environment
NODE_ENV="production"

# Redis URL (internal Docker network - don't change this)
REDIS_URL="redis://redis:6379"

# Public URL for screenshots and API access
# Replace with your home server's Tailscale IP
# Format: http://100.x.x.x:3006
PUBLIC_URL="http://YOUR_TAILSCALE_IP:3006"

# S3 Configuration (Optional - for future cloud storage migration)
# Leave empty to use local screenshot storage
# S3_ENDPOINT_URL=""
# S3_BUCKET_NAME=""
# S3_REGION=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
