{
  "name": "plugin",
  "version": "1.0.0",
  "scripts": {
    "prebuild": "pnpm --filter @sitemapper/shared build",
    "build": "pnpm run build:ui && pnpm run build:code && pnpm run fix-ui-path",
    "build:ui": "vite build",
    "build:code": "vite build --config vite.code.config.ts",
    "fix-ui-path": "test -f dist/src/ui.html && mv dist/src/ui.html dist/ui.html && rmdir dist/src 2>/dev/null || true",
    "watch": "concurrently \"vite build --watch\" \"vite build --config vite.code.config.ts --watch\"",
    "predev": "pnpm --filter @sitemapper/shared build",
    "dev": "pnpm run watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.92.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vite-plugin-singlefile": "^0.13.5",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@sitemapper/shared": "workspace:*",
    "@tabler/icons-react": "^3.35.0",
    "jotai": "^2.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
